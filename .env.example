# Base de données PostgreSQL
# Supabase : postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Docker local : postgresql://postgres:postgres@localhost:5432/prospection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/prospection?schema=public"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Resend (magic link)
RESEND_API_KEY="re_xxxxxxxxxxxx"
AUTH_RESEND_FROM="noreply@votredomaine.fr"

# Inngest (séquences et workers)
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
